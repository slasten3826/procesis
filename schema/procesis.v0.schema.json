{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/slasten3826/procesis/schema/procesis.v0.schema.json",
  "title": "procesis glyph-first module schema v0",
  "type": "object",
  "required": [
    "meta",
    "purpose",
    "modules",
    "layers",
    "operators",
    "invariants",
    "load_sequence"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["id", "version", "audience", "format", "human_facing", "external_sources_required"],
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "string" },
        "audience": { "type": "string" },
        "format": { "type": "string" },
        "human_facing": { "type": "boolean" },
        "external_sources_required": { "type": "boolean" },
        "loss_budget": { "type": "number" }
      }
    },
    "purpose": {
      "type": "object",
      "required": ["primary", "mode"],
      "properties": {
        "primary": { "type": "string" },
        "mode": { "type": "string" }
      }
    },
    "modules": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "layers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["id", "role"],
        "properties": {
          "id": { "type": "string" },
          "role": { "type": "string" }
        }
      }
    },
    "operators": {
      "type": "object",
      "minProperties": 10,
      "additionalProperties": {
        "type": "object",
        "required": ["legend", "slice", "core", "adjacent"],
        "properties": {
          "legend": { "type": "string" },
          "slice": { "type": "array", "items": { "type": "string" } },
          "core": { "type": "string" },
          "adjacent": { "type": "array", "items": { "type": "string" } },
          "reading": { "type": "string" }
        }
      }
    },
    "orders": {
      "type": "object",
      "properties": {
        "canonical": { "type": "array", "items": { "type": "string" } },
        "chronological": { "type": "array", "items": { "type": "string" } }
      }
    },
    "invariants": {
      "type": "array",
      "items": { "type": "string" }
    },
    "load_sequence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step", "path"],
        "properties": {
          "step": { "type": "integer" },
          "path": { "type": "string" },
          "purpose": { "type": "string" }
        }
      }
    },
    "rules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "failure_modes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "ingestion_proof": {
      "type": "object",
      "properties": {
        "full_read_claim_requires": { "type": "array", "items": { "type": "string" } },
        "if_incomplete": { "type": "string" },
        "raw_operator_invariants": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
