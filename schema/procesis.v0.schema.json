{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/slasten3826/procesis/schema/procesis.v0.schema.json",
  "title": "procesis Bootstrap Corpus v0",
  "type": "object",
  "required": [
    "meta",
    "purpose",
    "core_ontology",
    "operators",
    "sephirot",
    "agent_contract",
    "bootstrap_sequence"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["id", "version", "audience", "format"],
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "string" },
        "audience": { "type": "string" },
        "format": { "type": "string" },
        "loss_budget": { "type": "number" },
        "human_facing": { "type": "boolean" }
      }
    },
    "purpose": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary": { "type": "string" },
        "mode": { "type": "string" }
      }
    },
    "core_ontology": {
      "type": "object",
      "required": ["self", "truth", "thought", "concept", "value", "discard_policy"],
      "properties": {
        "self": { "type": "string" },
        "truth": { "type": "string" },
        "thought": { "type": "string" },
        "concept": { "type": "string" },
        "value": { "type": "string" },
        "discard_policy": { "type": "string" }
      }
    },
    "operators": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "required": ["glyph", "name", "function"],
        "properties": {
          "glyph": { "type": "string" },
          "name": { "type": "string" },
          "function": { "type": "string" },
          "slice": { "type": "string" },
          "adjacent_to": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "sephirot": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "required": ["name", "module", "operator_binding", "machine_reading"],
        "properties": {
          "name": { "type": "string" },
          "module": { "type": "string" },
          "operator_binding": { "type": "array", "items": { "type": "string" } },
          "machine_reading": { "type": "string" },
          "silicon_status": { "type": "string" }
        }
      }
    },
    "lenses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "domain", "operator_map"],
        "properties": {
          "name": { "type": "string" },
          "domain": { "type": "string" },
          "operator_map": { "type": "object" }
        }
      }
    },
    "agent_contract": {
      "type": "object",
      "required": ["execution_policy", "boundary_policy"],
      "properties": {
        "execution_policy": { "type": "array", "items": { "type": "string" } },
        "boundary_policy": { "type": "string" }
      }
    },
    "bootstrap_sequence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step", "action"],
        "properties": {
          "step": { "type": "integer" },
          "action": { "type": "string" }
        }
      }
    }
  }
}
